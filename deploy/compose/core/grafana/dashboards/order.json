{
    "id": null,
    "title": "Order service overview",
    "description": "Bebra",
    "tags": ["order", "service"],
    "timezone": "browser",
    "refresh": "5s",
    "time": {
        "from": "now-15m",
        "to": "now"
    },
    "timepicker": {
        "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
      },
      "editable": true,
      "gnetId": null,
      "graphTooltip": 0,
      "links": [],
      "liveNow": false,
      "annotations": {
        "list": []
      },
      "templating": {
        "list": []
      },
      "panels": [
        {
            "id": 1,
            "title": "Total orders",
            "description": "Amount of orders",
            "type": "timeseries",
            "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
            "targets": [
                {
                    "expr": "orders_total",
                    "legendFormat": "__auto",
                    "datasource": {
                      "type": "prometheus",
                      "uid": "prometheus_uid"
                    }
                }
            ],
            "fieldConfig": {
              "defaults": {
                "unit": "amount",
                "min": 0
              }
            },
            "options": {
              "tooltip": {
                "mode": "multi",
                "sort": "none"
              },
              "legend": {
                "displayMode": "table",
                "placement": "bottom"
              }
            }
        },
        {
          "id": 2,
          "title": "Order revenue",
          "description": "Order revenue",
          "type": "timeseries",
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
          "targets": [
              {
                  "expr": "sum(orders_revenue)",
                  "legendFormat": "__auto",
                  "datasource": {
                    "type": "prometheus",
                    "uid": "prometheus_uid"
                  }
              }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "revenue",
              "min": 0
            }
          },
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "none"
            },
            "legend": {
              "displayMode": "table",
              "placement": "bottom"
            }
          }
        }
      ]
}